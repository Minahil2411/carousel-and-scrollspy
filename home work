<!DOCTYPE html>
<html>
    <head>
        <title>
            Portfolio
        </title>
        <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">

        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>

        <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    </head>
    <body>
        <h1>
            Portfolio
        </h1>
        <nav id="navbar" class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
         <div class="container">
           <a class="navbar-brand" href="#">My Portfolio</a>
           <ul class="navbar-nav ms-auto">
             <li class="nav-item"><a class="nav-link" href="#home">Home</a></li><br>
             <li class="nav-item"><a class="nav-link" href="#about">About</a></li><br>
             <li class="nav-item"><a class="nav-link" href="#projects">Projects</a></li><br>
             <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li><br>
          </ul>
         </div>
        </nav>
        <div id="home" class="container-fluid bg-light p-5" style="margin-top:80px;">
           <h1>Home</h1>
           <p>Welcome to my portfolio</p>
        </div>

        <div id="about" class="container-fluid bg-info p-5">
          <h1>About Me</h1>
          <p>I am a web developer</p>
        </div>

        <div id="projects" class="container-fluid bg-warning p-5">
          <h1>Projects</h1>
              <div class="container">
            <div id="myCarousel" class="carousel slide" data-ride="carousel">
                <ol class="carousel-indicators">
                    <li data-target="#myCarousel" data-slide-to="0" class="active"></li>
                    <li data-target="#myCarousel" data-slide-to="1"></li>
                    <li data-target="#myCarousel" data-slide-to="2"></li>
                </ol>
                <div class="carousel-inner">
                    <div class="item active">
                        <img src="https://codingal.s3.amazonaws.com/media/Acp_style_Pagination.png"
                        alt="img1">
                    </div>
                    <div class="item">
                        <img src="https://codingal.s3.amazonaws.com/media/Acp_hobby_section.png"
                        alt="img2">
                    </div>
                    <div class="item">
                        <img src="https://codingal.s3.amazonaws.com/media/Acp_Text_Styling.png"
                        alt="img3">
                    </div>
                </div>
                <a class="left carousel-control" href="#myCarousel" data-slide="prev">
                    <span class="glyphicon glyphicon-chevron-left"></span>
                    <span class="sr-only">Previous</span>
                </a>
                 <a class="right carousel-control" href="#myCarousel" data-slide="next">
                    <span class="glyphicon glyphicon-chevron-right"></span>
                    <span class="sr-only">Next</span>
                </a>
            </div>
        </div>
        </div>

        <div id="contact" class="container-fluid bg-success p-5">
          <h1>Contact</h1>
          <p>Email: example@gmail.com</p>   
        </div>
    </body>
</html>
